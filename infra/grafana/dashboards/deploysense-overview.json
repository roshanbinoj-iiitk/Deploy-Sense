{
  "__inputs": [],
  "annotations": { "list": [] },
  "description": "DeploySense Platform Overview — Deployments, Risk, and Service Health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Deployments",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "deploysense_active_deployments",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Deployments/Day (7d)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "increase(deploysense_deployments_total[1d])",
          "legendFormat": "Deployments"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "hue"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Deployment Success Rate (24h)",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "1 - (increase(deploysense_deployment_failures_total[24h]) / increase(deploysense_deployments_total[24h]))",
          "legendFormat": "Success Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "title": "Risk Score Distribution (24h)",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (risk_level) (increase(deploysense_risk_calculations_total[24h]))",
          "legendFormat": "{{risk_level}}"
        }
      ]
    },
    {
      "title": "Rollbacks (7d)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "increase(deploysense_rollbacks_total[7d])",
          "legendFormat": "Rollbacks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Risk Engine Latency (p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(deploysense_risk_calculation_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, rate(deploysense_risk_calculation_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "hue"
          }
        }
      }
    },
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(deploysense_http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "API Error Rate (5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(deploysense_http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Worker Job Throughput",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(deploysense_jobs_processed_total[5m])",
          "legendFormat": "{{job_name}}"
        },
        {
          "expr": "rate(deploysense_worker_failures_total[5m])",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["deploysense", "platform", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "DeploySense — Platform Overview",
  "uid": "deploysense-overview"
}
